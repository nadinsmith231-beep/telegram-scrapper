{
  "buildCommand": "echo 'Static site with serverless functions'",
  "outputDirectory": ".",
  "functions": {
    "api/telegram.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/telegram" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
